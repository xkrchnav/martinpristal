---
import { Image } from 'astro:assets';

import featImg from '../assets/PXL_20251015_141756687.jpg';
import img2 from '../assets/PXL_20241113_133346628.jpg';
import img3 from '../assets/PXL_20241113_133457153.jpg';
import img4 from '../assets/PXL_20241113_134028950.jpg';
import img5 from '../assets/PXL_20241212_173348000.jpg';
import img6 from '../assets/PXL_20250304_092245605.jpg';
import img7 from '../assets/PXL_20250519_115904919.jpg';
import img8 from '../assets/PXL_20251013_094044224.jpg';
import img9 from '../assets/PXL_20251013_153826591.jpg';
import img10 from '../assets/PXL_20251015_073807604.jpg';

const regularImages = [
  img2, img3, img4, img5, img6, img7, img8, img9, img10
];
---

<section id="gallery" class="section">
  <div class="container">
    <h2 class="section__title">Ukázky práce</h2>
    <p class="section__subtitle">Pohled pod pokličku mých realizací.</p>
    
    <div class="gallery__layout">
      <!-- Featured Image -->
      <div class="gallery__item gallery__item--featured">
        <Image src={featImg} alt="Hlavní ukázka práce" width={800} height={800} loading="lazy" />
      </div>
      
      <!-- Grid for other images -->
      <div class="gallery__grid">
        {regularImages.map((img, index) => (
          <div class="gallery__item">
            <Image src={img} alt={`Ukázka práce ${index + 1}`} width={400} height={400} loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .gallery__layout {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .gallery__item {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(11, 19, 43, 0.06);
    aspect-ratio: 1;
    background: var(--color-surface);
  }

  .gallery__item--featured {
    aspect-ratio: 16/9;
  }

  @media (min-width: 768px) {
    .gallery__layout {
      flex-direction: row;
    }
    
    .gallery__item--featured {
      flex: 1 1 50%;
      aspect-ratio: auto; /* Let it fill height */
      min-height: 100%;
    }
    
    .gallery__grid {
      flex: 1 1 50%;
    }
  }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-md);
  }

  @media (min-width: 1024px) {
    .gallery__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .gallery__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-base);
  }

  .gallery__item:hover img {
    transform: scale(1.05);
  }
</style>