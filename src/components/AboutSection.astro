---
import { Image } from 'astro:assets';

interface Props {
  variant: 'creative' | 'professional';
  title: string;
  body: string;
  bullets: Array<{ title: string; text: string; icon?: string }>;
  image?: ImageMetadata;
  imageAlt?: string;
}

const { variant, title, body, bullets, image, imageAlt = '' } = Astro.props;
---

<section id="about" class="section">
  <div class="container">
    <h2 class="section__title">{title}</h2>
    <div class="about__grid">
      <div class="about__text">
        <p>{body}</p>
        <div class="about__bullets">
          {bullets.map((bullet) => (
            <div class="about__bullet">
              {variant === 'professional' && bullet.icon && (
                <div class="about__bullet-icon">{bullet.icon}</div>
              )}
              <div>
                <strong>{bullet.title}</strong>
                <p>{bullet.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      {image && (
        <div class="about__image">
          <Image src={image} alt={imageAlt} width={600} height={450} />
        </div>
      )}
    </div>
  </div>
</section>
