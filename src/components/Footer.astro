<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <strong>MP Electro & Services</strong>
      <p>Martin Přistal — Profesionální elektroinstalace a průmyslová automatizace</p>
    </div>
    <div class="footer__copy">
      <p>&copy; {new Date().getFullYear()} Martin Přistal — MP Electro & Services. Všechna práva vyhrazena.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding-block: var(--space-2xl);
    margin-top: var(--space-3xl);
    background: var(--color-bg);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    align-items: center;
    text-align: center;
  }

  .footer__brand strong {
    font-size: 1.1rem;
    display: block;
    margin-bottom: var(--space-xs);
    color: var(--color-text);
  }

  .footer__brand p {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .footer__copy p {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  @media (min-width: 768px) {
    .footer__inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>