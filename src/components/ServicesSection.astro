---

<section id="services" class="section">
  <div class="container">
    <h2 class="section__title">Služby</h2>
    <p class="section__subtitle">Komplexní řešení pro vaše projekty, od rodinných domů po průmyslovou automatizaci.</p>
    <div class="services__grid">
      {services.map((service) => (
        <div class="service-card">
          <div class="service-card__icon" set:html={service.icon} />
          <h3 class="service-card__title">{service.title}</h3>
          <p class="service-card__desc">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
    .services__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .services__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .service-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-xl);
    transition: box-shadow var(--transition-base), border-color var(--transition-base), transform var(--transition-base);
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .service-card:hover {
    box-shadow: 0 4px 20px rgba(11, 19, 43, 0.08);
    border-color: var(--color-lime);
    transform: translateY(-4px);
  }

  /* Make SVG icons render properly */
  .service-card__icon {
    width: 56px;
    height: 56px;
    background: rgba(192, 214, 103, 0.15); /* Light lime bg */
    color: var(--color-accent); /* Lime accent */
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-md);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .service-card:hover .service-card__icon {
    background: var(--color-accent);
    color: var(--color-navy);
  }

  .service-card__icon :global(svg) {
    width: 32px;
    height: 32px;
  }

  .service-card__title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .service-card__desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    flex-grow: 1;
  }

  @media (prefers-color-scheme: dark) {
    .service-card:hover {
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4);
    }
    
    .service-card__icon {
      background: rgba(192, 214, 103, 0.1);
    }
    
    .service-card:hover .service-card__icon {
      background: var(--color-accent);
      color: #0B132B; /* Navy */
    }
  }
</style>