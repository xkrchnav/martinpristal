---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import PhotoStrip from '../components/PhotoStrip.astro';
import ServicesSection from '../components/ServicesSection.astro';
import GallerySection from '../components/GallerySection.astro';
import ContactSection from '../components/ContactSection.astro';

import martinFb from '../assets/martin_fb.jpg';

import strip1 from '../assets/PXL_20260226_141631970.jpg';
import strip2 from '../assets/PXL_20251118_163706687.jpg';
import strip3 from '../assets/PXL_20251114_175140526.jpg';
import strip4 from '../assets/PXL_20241212_173348000.jpg';

import gallery1 from '../assets/PXL_20260226_141631970.jpg';
import gallery2 from '../assets/PXL_20251118_163706687.jpg';
import gallery3 from '../assets/PXL_20251118_162533352.jpg';
import gallery4 from '../assets/PXL_20251114_175140526.jpg';
import gallery5 from '../assets/PXL_20251024_132850051.jpg';
import gallery6 from '../assets/PXL_20241212_173348000.jpg';
import gallery7 from '../assets/PXL_20241113_133650402.jpg';
import gallery8 from '../assets/IMG_20250731_114924_186.jpg';

const photoStripImages = [
  { src: strip1, alt: 'Průmyslový rozvaděč — precizní práce' },
  { src: strip2, alt: 'Silnoproudé rozvody — instalace' },
  { src: strip3, alt: 'Elektroinstalace — detail práce' },
  { src: strip4, alt: 'Profesionální elektromontáž' },
];

const silnoproudServices = [
  { title: 'Kompletní elektroinstalace', description: 'Novostavby, byty a rodinné domy od projektu po revizi.', icon: '⚡' },
  { title: 'Rekonstrukce rozvodů', description: 'Modernizace zastaralých instalací dle aktuálních norem.', icon: '🔧' },
  { title: 'Montáže rozvaděčů', description: 'Rozvaděče, jističe a ochranné prvky pro bytové i průmyslové objekty.', icon: '🔌' },
  { title: 'Připojení spotřebičů', description: 'Profesionální připojení a revize spotřebičů a zásuvkových okruhů.', icon: '🏭' },
  { title: 'Elektrické přípojky', description: 'Přípojky NN, rozvodné skříně a koordinace s energetickými firmami.', icon: '🏗️' },
];

const slaboproudServices = [
  { title: 'Průmyslová automatizace', description: 'Instalace, servis a programování výrobních linek a PLC systémů.', icon: '🤖' },
  { title: 'Datové rozvody', description: 'Strukturovaná kabeláž, datové racky a síťová infrastruktura.', icon: '🌐' },
  { title: 'Chytré domácnosti', description: 'IoT řešení a smart home integrace pro moderní bydlení.', icon: '🏠' },
  { title: 'Servis výrobních linek', description: 'Programování, diagnostika a údržba průmyslových automatizačních systémů.', icon: '⚙️' },
  { title: 'Kamerové a zabezpečovací systémy', description: 'Příprava kabeláže a instalace pro CCTV a zabezpečovací technika.', icon: '📷' },
];

const galleryImages = [
  { src: gallery1, alt: 'Průmyslový rozvaděč — precizní zapojení' },
  { src: gallery2, alt: 'Silnoproudé rozvody — detail' },
  { src: gallery3, alt: 'Elektrický rozvaděč — kompletace' },
  { src: gallery4, alt: 'Elektroinstalace — kvalitní řemeslo' },
  { src: gallery5, alt: 'Rozvodná skříň — průmyslové řešení' },
  { src: gallery6, alt: 'Profesionální elektromontáž' },
  { src: gallery7, alt: 'Technické zázemí — hotový projekt' },
  { src: gallery8, alt: 'Realizace — kompletní instalace' },
];
---

<BaseLayout title="Martin Přistal — MP Electro & Services" variant="professional">
  <Header variant="professional" />

  <HeroSection
    variant="professional"
    headline="Profesionální elektroinstalace a průmyslová automatizace"
    subheadline="Ing. Martin Přistal & tým. Spojujeme inženýrské know-how z VUT, německou preciznost a letité zkušenosti z praxe. Od rodinných domů po průmyslové haly."
    body="Hledáte spolehlivého partnera pro komplexní zakázku? Zajišťujeme montáže výrobních linek, programování PLC systémů a kompletní silnoproudé i slaboproudé instalace pro komerční i soukromé objekty. Precizně, v termínu a s technologickým přehledem."
    ctaText="Poptat nezávaznou konzultaci"
    ctaHref="#contact"
    image={martinFb}
    imageAlt="Ing. Martin Přistal"
  />

  <PhotoStrip images={photoStripImages} />

  <ServicesSection
    variant="professional"
    title="Silnoproudé instalace"
    body="Kompletní elektroinstalace na klíč — od základních rozvodů až po komplexní instalace v novostavbách a rekonstrukcích."
    services={silnoproudServices}
  />

  <ServicesSection
    variant="professional"
    title="Slaboproud a automatizace"
    body="Moderní technologie a průmyslová řešení pro inteligentní budovy a výrobní provozy."
    services={slaboproudServices}
  />

  <GallerySection
    variant="professional"
    title="Reference a realizace"
    images={galleryImages}
  />

  <ContactSection
    variant="professional"
    title="Poptat nezávaznou konzultaci"
    description="Potřebujete spolehlivého partnera pro elektroinstalace nebo průmyslovou automatizaci? Neváhejte se ozvat."
    email="info@mpelectro.cz"
    phone="+420 123 456 789"
  />

  <Footer variant="professional" />
</BaseLayout>
