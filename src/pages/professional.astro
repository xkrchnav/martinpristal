---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import GallerySection from '../components/GallerySection.astro';
import ContactSection from '../components/ContactSection.astro';

import profilProfi from '../assets/profil_profi.jpg';
import logo from '../assets/logo.png';

import gallery1 from '../assets/PXL_20260226_141631970.jpg';
import gallery2 from '../assets/PXL_20251118_163706687.jpg';
import gallery3 from '../assets/PXL_20251118_162533352.jpg';
import gallery4 from '../assets/PXL_20251114_175140526.jpg';
import gallery5 from '../assets/PXL_20251024_132850051.jpg';
import gallery6 from '../assets/PXL_20241212_173348000.jpg';
import gallery7 from '../assets/PXL_20241113_133650402.jpg';
import gallery8 from '../assets/IMG_20250731_114924_186.jpg';

const services = [
  {
    title: 'Průmyslová automatizace',
    description: 'Instalace, servis a údržba výrobních linek, PLC systémy a periferie.',
    icon: '🏭',
  },
  {
    title: 'Velké objekty & B2B',
    description: 'Komplexní elektromontáže pro haly, obchodní centra a infrastrukturu.',
    icon: '🏗️',
  },
  {
    title: 'Rezidenční sektor',
    description: 'Moderní elektroinstalace pro novostavby a chytré domácnosti.',
    icon: '🏠',
  },
];

const aboutBullets = [
  {
    title: 'Technická autorita',
    text: 'Bývalý pedagog elektrotechniky a absolvent VUT (IoT a Telekomunikace).',
    icon: '🎓',
  },
  {
    title: 'Kapacita pro velké projekty',
    text: 'Disponujeme sehraným realizačním týmem pro nákupní centra, nemocnice a administrativní budovy.',
    icon: '👷',
  },
  {
    title: 'Zahraniční standardy',
    text: 'Léta praxe z náročného trhu v Německu aplikovaná na české projekty.',
    icon: '🇩🇪',
  },
];

const galleryImages = [
  { src: gallery1, alt: 'Průmyslový rozvaděč — precizní zapojení' },
  { src: gallery2, alt: 'Silnoproudé rozvody — detail' },
  { src: gallery3, alt: 'Elektrický rozvaděč — kompletace' },
  { src: gallery4, alt: 'Elektroinstalace — kvalitní řemeslo' },
  { src: gallery5, alt: 'Rozvodná skříň — průmyslové řešení' },
  { src: gallery6, alt: 'Profesionální elektromontáž' },
  { src: gallery7, alt: 'Technické zázemí — hotový projekt' },
  { src: gallery8, alt: 'Realizace — kompletní instalace' },
];
---

<BaseLayout title="Ing. Martin Přistal — Profesionální elektroinstalace" variant="professional">
  <Header variant="professional" />

  <HeroSection
    variant="professional"
    headline="Profesionální elektroinstalace a průmyslová automatizace"
    subheadline="Ing. Martin Přistal & tým. Spojujeme inženýrské know-how z VUT, německou preciznost a letité zkušenosti z praxe. Od rodinných domů po průmyslové haly."
    body="Hledáte spolehlivého partnera pro komplexní zakázku? Zajišťujeme montáže výrobních linek, programování PLC systémů a kompletní silnoproudé i slaboproudé instalace pro komerční i soukromé objekty. Precizně, v termínu a s technologickým přehledem."
    ctaText="Poptat nezávaznou konzultaci"
    ctaHref="#contact"
    image={profilProfi}
    imageAlt="Ing. Martin Přistal — profesionální portrét"
  />

  <AboutSection
    variant="professional"
    title="Kvalifikace, na kterou se můžete spolehnout"
    body="Úspěšný projekt vyžaduje víc než jen manuální zručnost. Vyžaduje hluboké pochopení fyziky, IT a norem. S akademickým zázemím z VUT, praxí mistra odborného výcviku a mezinárodními zkušenostmi garantuji technickou bezchybnost každého řešení."
    bullets={aboutBullets}
    image={logo}
    imageAlt="MP Electro & Services — logo"
  />

  <ServicesSection
    variant="professional"
    title="Naše specializace"
    body="Jsme připraveni naskočit do běžícího projektu nebo převzít realizaci na klíč."
    services={services}
  />

  <GallerySection
    variant="professional"
    title="Reference a realizace"
    images={galleryImages}
  />

  <ContactSection
    variant="professional"
    title="Poptat nezávaznou konzultaci"
    description="Potřebujete spolehlivého partnera pro elektroinstalace nebo průmyslovou automatizaci? Neváhejte se ozvat."
    email="info@mpelectro.cz"
    phone="+420 123 456 789"
  />

  <Footer variant="professional" />
</BaseLayout>
