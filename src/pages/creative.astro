---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/HeroSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ServicesSection from '../components/ServicesSection.astro';
import GallerySection from '../components/GallerySection.astro';
import ContactSection from '../components/ContactSection.astro';

import profilExtra from '../assets/profil_extra.jpg';
import vsehodruhu from '../assets/vsehodruhu.jpg';

import gallery1 from '../assets/PXL_20260226_141631970.jpg';
import gallery2 from '../assets/PXL_20260225_181503857.jpg';
import gallery3 from '../assets/PXL_20251118_162533352.jpg';
import gallery4 from '../assets/PXL_20251118_163706687.jpg';
import gallery5 from '../assets/PXL_20251114_175140526.jpg';
import gallery6 from '../assets/PXL_20251024_132850051.jpg';
import gallery7 from '../assets/PXL_20241212_173348000.jpg';
import gallery8 from '../assets/IMG_20250731_114924_186.jpg';

const services = [
  {
    title: 'B2B & Průmysl',
    description: 'Automatizace, PLC, údržba výrobních linek.',
    icon: '⚙️',
  },
  {
    title: 'Rezidentní elektro',
    description: 'Kompletní rozvody pro novostavby i citlivé rekonstrukce.',
    icon: '🏠',
  },
  {
    title: 'Všehochuť a mechanika',
    description: 'Komplexní instalace přesahující čisté elektro.',
    icon: '🔧',
  },
];

const aboutBullets = [
  {
    title: 'Adrenalin a přesnost',
    text: 'Zvládám stres. Tam, kde jiní panikaří, já vidím jasné schéma.',
  },
  {
    title: 'Nejen dráty',
    text: 'Potřebujete pomoct i s konstrukcí? Podívejte se do mé galerie, dřevo a mechanika mi nejsou cizí.',
  },
  {
    title: 'Tým, co má jiskru',
    text: 'Na obří projekty nejsem sám. Mám partu profíků, se kterou zvládáme i průmyslové haly.',
  },
];

const galleryImages = [
  { src: gallery1, alt: 'Elektroinstalace — rozvaděč a zapojení' },
  { src: gallery2, alt: 'Průmyslová automatizace — kabeláž' },
  { src: gallery3, alt: 'Elektrický rozvaděč — detail' },
  { src: gallery4, alt: 'Silnoproudé rozvody' },
  { src: gallery5, alt: 'Kompletní elektroinstalace' },
  { src: gallery6, alt: 'Rozvodná skříň — průmysl' },
  { src: gallery7, alt: 'Elektromontáž — hotová práce' },
  { src: gallery8, alt: 'Instalace a zapojení' },
];
---

<BaseLayout title="Martin Přistal — Kreativní" variant="creative">
  <Header variant="creative" />

  <HeroSection
    variant="creative"
    headline="Skončil jsem jako pěšák v cizině. Teď tvořím energii doma."
    subheadline="Jmenuji se Martin Přistal. Zkrotil jsem volný pád i německý průmysl. Dnes s mým týmem oživujeme chytré domy, stavíme průmyslové linky a nebojíme se vzít za práci."
    body="Říká se, že s elektřinou si není radno zahrávat. Já ji učil, programoval a instaloval v těch nejnáročnějších podmínkách. Ať už potřebujete zapojit novostavbu, naprogramovat PLC linku, nebo postavit pergolu, udělám to s precizností inženýra a tahem na branku."
    ctaText="Pojďme na váš projekt"
    ctaHref="#contact"
    image={profilExtra}
    imageAlt="Martin Přistal — tandemový seskok"
  />

  <AboutSection
    variant="creative"
    title="Z laboratoří VUT přes Německo zpět na rodnou hroudu"
    body="Strávil jsem roky studiem IoT na VUT, učením fyziky a prací na velkých projektech v Německu. Zjistil jsem ale jednu věc: nechci být jen kolečkem ve stroji někoho jiného. Vrátil jsem se domů, abych pracoval na sebe, pro vás. Dávám do práce nejen německou preciznost, ale hlavně české srdce a ruce, které se nebojí žádného řemesla."
    bullets={aboutBullets}
    image={vsehodruhu}
    imageAlt="Martin Přistal — stavba pergoly"
  />

  <ServicesSection
    variant="creative"
    title="Od chytrého domu po tovární linku"
    body="Nedělám rozdíly mezi tím, jestli tahám kabely ve vaší vysněné novostavbě, nebo oživuji PLC systémy v obchoďáku. Každý spoj musí být dokonalý."
    services={services}
  />

  <GallerySection
    variant="creative"
    title="Galerie"
    images={galleryImages}
  />

  <ContactSection
    variant="creative"
    title="Pojďme spolupracovat"
    description="Máte projekt, který potřebuje precizní elektrikáře? Ozvěte se a domluvíme se."
    email="info@mpelectro.cz"
    phone="+420 123 456 789"
  />

  <Footer variant="creative" />
</BaseLayout>
